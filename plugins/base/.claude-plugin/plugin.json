{
	"name": "base",
	"description": "Basic skills for working with Zantarix projects",
	"author": {
		"name": "Zantarix",
		"email": "github@zantarix.com"
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Edit|Write|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/guard-adr.sh",
						"timeout": 5,
						"statusMessage": "Checking ADR ownership..."
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/format.sh",
						"timeout": 5,
						"statusMessage": "Formatting file..."
					}
				]
			}
		]
	}
}
